# Environment variables — copy this to .env and fill in your values
# On Render, set these in the "Environment" tab of your service.

# A secret key — the Chrome extension must send this in x-api-key header
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=changeme

# How many days to keep email data before auto-delete (default: 7)
RETENTION_DAYS=7

# Where to store the SQLite database file
# On Render with persistent disk, set to: /data/tracker.db
DB_PATH=./tracker.db
